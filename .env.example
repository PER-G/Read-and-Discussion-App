# Anthropic / Claude API-Key
# Hol dir einen Key unter: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Welches Claude-Modell verwendet werden soll
# Empfohlen: claude-sonnet-4-6 (schnell & gut). Alternativ: claude-opus-4-8 (höchste Qualität)
CLAUDE_MODEL=claude-sonnet-4-6

# Port für den lokalen Backend-Server
PORT=8787

# --- Login-Schutz (PFLICHT für die Veröffentlichung!) ---
# Ohne AUTH_USER + AUTH_PASS ist KEIN Login möglich (die App ist dann gesperrt).
AUTH_USER=PER
AUTH_PASS=dein-sicheres-passwort
# Geheimer Schlüssel zum Signieren der Login-Tokens. Erzeuge einen zufälligen Wert, z. B.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=zufaelliger-langer-geheimer-string
