# Anthropic / Claude API-Key
# Hol dir einen Key unter: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Welches Claude-Modell verwendet werden soll
# Empfohlen: claude-sonnet-4-6 (schnell & gut). Alternativ: claude-opus-4-8 (höchste Qualität)
CLAUDE_MODEL=claude-sonnet-4-6

# Port für den lokalen Backend-Server
PORT=8787
