{
  "name": "read-and-discussion-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Lokale Web-App: PDF hochladen, von Claude zusammenfassen lassen, kapitelweise vorlesen und mit der KI diskutieren.",
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  }
}
